# Keep the build context small + deterministic.
.git
.gitignore
**/__pycache__/
**/*.py[cod]

# Local envs
.venv/
venv/
env/

# Local media + artifacts (model is fetched in the Dockerfile; uploads are runtime)
*.mp4
*.MP4
*.mov
*.MOV
*.avi
backend/uploads/
backend/models/*.task
*.log

# Not needed in the image
node_modules/
brandbook-v2.html
DEPLOY.md
README.md
