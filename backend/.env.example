# Copy to .env (git-ignored) or set these as real environment variables.

# LLM coaching (Milestone 5). Google AI Studio key. If unset, the app still
# works — it just skips the AI recommendations.
GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional path overrides
# VA_MODELS_DIR=
# VA_UPLOADS_DIR=

# Optional CORS lock-down for production (comma-separated origins; default *)
# VA_CORS_ORIGINS=https://your-frontend.example
