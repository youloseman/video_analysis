# Copy to .env (git-ignored) or set these as real environment variables.

# LLM coaching (Milestone 5). Google AI Studio key. If unset, the app still
# works — it just skips the AI recommendations.
GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional path overrides
# VA_MODELS_DIR=
# VA_UPLOADS_DIR=

# Optional CORS lock-down for production (comma-separated origins; default *)
# VA_CORS_ORIGINS=https://your-frontend.example

# Abuse guard: analyses per client IP per rolling 24h (default 3; 0 disables)
# VA_RATE_LIMIT_PER_DAY=3

# --- Accounts / billing ---
# Postgres URL in prod (Railway); defaults to a local SQLite file if unset.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# MUST be overridden in prod (any long random string).
# JWT_SECRET=change-me-to-a-long-random-string
# Account auto-promoted to the admin tier (5 analyses/day) on startup.
# ADMIN_EMAIL=you@example.com
